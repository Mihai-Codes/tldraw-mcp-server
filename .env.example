# tldraw MCP Server Configuration

# Canvas server URL (default: http://127.0.0.1:3000)
EXPRESS_SERVER_URL=http://127.0.0.1:3000

# Canvas server port (default: 3000)
PORT=3000

# Canvas server host (default: 127.0.0.1, use 0.0.0.0 for Docker/remote)
HOST=127.0.0.1

# tldraw SDK License Key (required for SDK features)
# Get your key at https://tldraw.dev/quick-start
TLDRAW_LICENSE_KEY=your-license-key-here
